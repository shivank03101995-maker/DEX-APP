# Never commit your real PRIVATE_KEY. Use a funded deployer account.
PRIVATE_KEY=

# RPC endpoints
POLYGON_RPC_URL=
AMOY_RPC_URL=

# Optional: for contract verification
POLYGONSCAN_API_KEY=

# Optional: reuse existing deployments (set these to skip redeploying)
FACTORY_ADDRESS=
ROUTER_ADDRESS=

# Optional: reuse existing Token A/B so seed only runs addLiquidity + swap (no new token deploy)
